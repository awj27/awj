---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Hl from '../components/Hl.astro';
import Btn from '../components/Btn.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

// Career milestones, newest → oldest. MEDDICC Founder/CEO is the apex,
// rendered as a separate card on top of the path. MEDDICC MEDIA appears as
// a satellite line inside the apex card (not its own milestone).
const milestones = [
  { year: '2019 — 2021', role: 'MD, EMEA',           company: 'Branch',                    logo: '/media/career-logos/branch.png' },
  { year: '2017 — 2019', role: 'Head of Sales',      company: 'Poq',                       logo: '/media/career-logos/poq.png' },
  { year: '2017',        role: 'Sales Director',     company: 'Tealium',                   logo: '/media/career-logos/tealium.png' },
  { year: '2015 — 2017', role: 'Account Executive',  company: 'Sprinklr',                  logo: '/media/career-logos/sprinklr.png' },
  { year: '2013 — 2015', role: 'Account Executive',  company: 'Oracle',                    logo: '/media/career-logos/oracle.png' },
  { year: '2008 — 2013', role: 'VP of Sales',        company: 'ECI Software Solutions',    logo: '/media/career-logos/eci.png' },
  { year: '2006 — 2008', role: 'Account Executive',  company: 'ECI Software Solutions',    logo: '/media/career-logos/eci.png' },
  { year: '2004 — 2006', role: 'Head of Sales',      company: 'Everest Home Improvements', logo: '/media/career-logos/everest.png' },
  { year: '2004',        role: 'Store Manager',      company: 'Phones 4u',                 logo: '/media/career-logos/phones4u.png' },
  { year: '2001 — 2004', role: 'Entertainer & DJ',   company: 'Potters Resort',            logo: '/media/career-logos/potters.png' },
];
---
<Layout
  title="About — AWJ"
  description="Andy Whyte. Founder/CEO of MEDDICC, best-selling author, MEDDPICC superfan. Why AWJ exists."
>
  {/* HERO */}
  <section class="ab-hero">
    <div class="site-shell ab-hero__inner">
      <div class="ab-hero__copy">
        <Eyebrow>Who is this?</Eyebrow>
        <h1 class="ab-hero__title">
          Andy Whyte. <Hl>Founder/CEO</Hl>, best-selling author, dad, human.
        </h1>
        <p class="ab-hero__lead">Outcome-oriented, results-driven. MEDDIC superfan.</p>
      </div>
      <div class="ab-hero__photo">
        <img
          src="/media/portrait/andy-leather-jacket.webp"
          alt="Andy Whyte — Founder and CEO of MEDDICC"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  {/* BIO — real text, in Andy's voice */}
  <section class="ab-bio">
    <div class="content-shell prose">
      <h2>From B-player to founder.</h2>
      <p>I'm the founder and CEO of MEDDICC, but before that, I spent 17 years as an individual contributor and sales leader.</p>
      <p>There was a time early in my career when I felt like no matter how much work I put in, I was playing sales on hard mode while everyone around me was playing it on easy mode.</p>
      <p>That was when I discovered MEDDIC and unlocked my full potential as a salesperson. It was like I went from a B-player version of myself to the A-player version.</p>
      <p>I realised that while the best organisations I knew all used MEDDIC, nobody was talking about it. I started to write about it, and quickly found a keen audience.</p>
      <p>Blog posts turned into a book, and the book turned into a bestseller.</p>
      <p>Today, MEDDICC has helped over <strong>100,000 people</strong> level up using MEDDPICC.</p>
    </div>
  </section>

  {/* CAREER JOURNEY — compact path with logo milestones */}
  <section class="ab-journey">
    <div class="ab-journey__head">
      <Eyebrow>The long way round</Eyebrow>
      <h2 class="ab-journey__title">From entertainer to founder. <Hl>Twenty years.</Hl> One trajectory.</h2>
    </div>

    <div class="ab-journey__path">
      {/* APEX — present-day MEDDICC, sits on top of the path */}
      <div class="jrn__apex">
        <div class="jrn__apex-flag">★ You are here</div>
        <div class="jrn__apex-inner">
          <span class="jrn__logo jrn__logo--apex" aria-hidden="true">
            <img src="/media/career-logos/meddicc.png" alt="" />
          </span>
          <div class="jrn__apex-text">
            <span class="jrn__year jrn__year--apex">2021 — present</span>
            <h3 class="jrn__apex-role">Founder &amp; CEO · MEDDICC</h3>
          </div>
        </div>
        <div class="jrn__also">
          <img src="/media/career-logos/meddicc-media.png" alt="" class="jrn__also-logo" />
          <span><strong>Creative Director</strong> · MEDDICC MEDIA · 2022 — present</span>
        </div>
      </div>

      {/* PATH — ten milestones, oldest at the bottom */}
      <ol class="jrn" aria-label="Career milestones">
        {milestones.map((m) => (
          <li class="jrn__row">
            <span class="jrn__logo" aria-hidden="true">
              <img src={m.logo} alt="" loading="lazy" />
            </span>
            <div class="jrn__text">
              <span class="jrn__year">{m.year}</span>
              <span class="jrn__role-co">
                <span class="jrn__role">{m.role}</span>
                <span class="jrn__co"> · {m.company}</span>
              </span>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* THREE PILLARS — the WHY for AWJ */}
  <section class="ab-pillars">
    <div class="content-shell prose">
      <h2>Why AWJ exists.</h2>
      <p>AWJ is a notebook page that earned the right to be on a billboard. It's the public form of the journal I've kept in private — applied thinking from someone who's done both the work and the worrying.</p>
      <p>Three pillars:</p>
      <p><strong>Sales — authority.</strong> MEDDICC, deal inspection, sales as a thinking discipline.</p>
      <p><strong>Founder — operator.</strong> Bootstrap SaaS, trade-offs under uncertainty, no theatre.</p>
      <p><strong>Human — truth.</strong> Controlled lessons from failure. The quality of your thinking determines the quality of your life.</p>
      <p>If that resonates, the journal arrives Fridays.</p>
    </div>
    <div class="ab-pillars__cta">
      <Btn href="/journal/" tone="dark">Read the archive</Btn>
      <Btn href="/subscribe/" tone="ghost">Subscribe</Btn>
    </div>
  </section>

  {/* SUBSCRIBE STRIP */}
  <section class="ab-sub awj-bg-paper-blue">
    <div class="site-shell ab-sub__inner">
      <Eyebrow color="#FFCE00">Frictionless</Eyebrow>
      <h2 class="ab-sub__h">One entry. <Hl>Every Friday.</Hl> No noise.</h2>
      <SubscribeForm tone="dark" />
    </div>
  </section>
</Layout>

<style>
  /* ---------------- HERO ---------------- */
  .ab-hero { padding: var(--sp-9) 0 var(--sp-7); border-bottom: var(--border-hard); }
  .ab-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-7);
    align-items: center;
    padding: 0 var(--gutter);
  }
  @media (min-width: 900px) { .ab-hero__inner { grid-template-columns: 1.3fr 1fr; } }
  .ab-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 0.95;
    font-size: clamp(40px, 6.5vw, 96px);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .ab-hero__lead {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    margin: 0;
    color: var(--fg-2);
  }
  /* New portrait container: 4:5 aspect, image cover-fitted but anchored to the
     top so the head is never the part that gets clipped. The leather-jacket
     portrait is naturally 2:3 — at 4:5 it crops only from the bottom. */
  .ab-hero__photo {
    border: var(--border-hard);
    background: var(--awj-yellow);
    background-image: url('/assets/textures/paper_yellow.png');
    background-size: cover;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    position: relative;
  }
  .ab-hero__photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    /* image is already monochrome — no extra grayscale filter needed */
  }

  /* ---------------- BIO ---------------- */
  .ab-bio { padding: var(--sp-8) 0 var(--sp-7); }
  .ab-bio .prose { padding: 0 var(--gutter); }

  /* ---------------- CAREER JOURNEY (compact) ---------------- */
  .ab-journey {
    padding: var(--sp-7) 0;
    border-top: var(--border-hard);
    background: var(--awj-paper);
    background-image: url('/assets/textures/paper_white.png');
    background-size: 600px;
  }
  .ab-journey__head {
    max-width: 640px;
    margin: 0 auto var(--sp-5);
    padding: 0 var(--gutter);
  }
  .ab-journey__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(28px, 4vw, 48px);
    line-height: 0.98;
    letter-spacing: -0.005em;
    margin: var(--sp-2) 0 0;
  }
  .ab-journey__path {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  /* APEX — present-day MEDDICC card */
  .jrn__apex {
    position: relative;
    background: var(--awj-yellow);
    background-image: url('/assets/textures/paper_yellow.png');
    background-size: cover;
    border: var(--border-thicc);
    padding: var(--sp-4) var(--sp-5);
    margin-bottom: var(--sp-3);
    box-shadow: var(--shadow-paper);
  }
  .jrn__apex-flag {
    position: absolute;
    top: -10px;
    left: 14px;
    background: var(--awj-black);
    color: var(--awj-yellow);
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 3px 8px;
    transform: rotate(-2deg);
  }
  .jrn__apex-inner {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: var(--sp-3);
    align-items: center;
  }
  .jrn__apex-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .jrn__apex-role {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(20px, 3.2vw, 30px);
    line-height: 0.95;
    margin: 0;
    color: var(--awj-black);
    letter-spacing: -0.005em;
  }
  .jrn__year--apex { color: rgba(0,0,0,0.7); }
  .jrn__also {
    margin-top: var(--sp-3);
    padding-top: var(--sp-3);
    border-top: 1.5px solid rgba(0,0,0,0.3);
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 12.5px;
    color: var(--awj-black);
  }
  .jrn__also-logo {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--awj-white);
    border: 1.5px solid var(--awj-black);
    padding: 2px;
    flex-shrink: 0;
    object-fit: contain;
    box-sizing: border-box;
  }

  /* PATH — milestone list with dashed spine */
  .jrn {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .jrn::before {
    content: '';
    position: absolute;
    left: 23px;          /* aligns with logo center (column 1 = 46px wide) */
    top: 12px;
    bottom: 12px;
    width: 0;
    border-left: 2px dashed rgba(0,0,0,0.55);
    z-index: 0;
  }
  .jrn__row {
    position: relative;
    display: grid;
    grid-template-columns: 46px 1fr;
    gap: var(--sp-3);
    align-items: center;
    padding: 5px 0;
    z-index: 1;
  }

  /* Logo cell (used by both apex and rows) */
  .jrn__logo {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--awj-white);
    border: 2px solid var(--awj-black);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 1px 0 rgba(0,0,0,0.06), 0 4px 10px -4px rgba(0,0,0,0.2);
    box-sizing: border-box;
  }
  .jrn__logo img {
    width: 78%;
    height: 78%;
    object-fit: contain;
  }
  .jrn__logo--apex {
    width: 56px;
    height: 56px;
  }

  .jrn__text {
    display: grid;
    grid-template-columns: 96px 1fr;
    column-gap: 10px;
    align-items: baseline;
    min-width: 0;
  }
  .jrn__year {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-3);
    white-space: nowrap;
  }
  .jrn__role-co { min-width: 0; }
  .jrn__role {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: 17px;
    line-height: 1;
    color: var(--awj-black);
    letter-spacing: -0.005em;
  }
  .jrn__co {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--fg-2);
  }

  /* MOBILE — drop year onto its own line, slim everything */
  @media (max-width: 540px) {
    .jrn__row { grid-template-columns: 38px 1fr; gap: var(--sp-2); }
    .jrn__logo { width: 38px; height: 38px; }
    .jrn::before { left: 19px; }
    .jrn__text { display: block; }
    .jrn__year { display: block; margin-bottom: 2px; }
    .jrn__apex-inner { grid-template-columns: 48px 1fr; }
    .jrn__logo--apex { width: 48px; height: 48px; }
  }

  /* ---------------- PILLARS ---------------- */
  .ab-pillars { padding: var(--sp-8) 0 var(--sp-9); border-top: var(--border-hard); }
  .ab-pillars .prose { padding: 0 var(--gutter); }
  .ab-pillars__cta {
    margin-top: var(--sp-7);
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    padding: 0 var(--gutter);
    max-width: var(--content-max);
    margin-left: auto;
    margin-right: auto;
  }

  /* ---------------- SUBSCRIBE STRIP ---------------- */
  .ab-sub { position: relative; overflow: hidden; }
  .ab-sub__inner { padding: var(--sp-9) var(--gutter); position: relative; max-width: var(--site-max); margin: 0 auto; }
  .ab-sub__h {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(40px, 7vw, 96px);
    line-height: 1;
    margin: var(--sp-3) 0 var(--sp-6);
    color: var(--awj-white);
    max-width: 18ch;
  }
</style>
