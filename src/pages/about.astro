---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Hl from '../components/Hl.astro';
import Btn from '../components/Btn.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

// Career milestones, newest → oldest. The MEDDICC Founder/CEO role is the
// apex, rendered separately above the path. MEDDICC MEDIA appears as a
// satellite badge inside the apex card (not its own milestone).
const milestones = [
  { year: '2019 — 2021', role: 'MD, EMEA',                      company: 'Branch' },
  { year: '2017 — 2019', role: 'Head of Sales',                 company: 'Poq' },
  { year: '2017',        role: 'Sales Director',                company: 'Tealium' },
  { year: '2015 — 2017', role: 'Account Executive',             company: 'Sprinklr' },
  { year: '2013 — 2015', role: 'Account Executive',             company: 'Oracle' },
  { year: '2008 — 2013', role: 'VP of Sales, ES Tech Group',    company: 'ECI Software Solutions' },
  { year: '2006 — 2008', role: 'Account Executive',             company: 'ECI Software Solutions' },
  { year: '2004 — 2006', role: 'Head of Sales — Home Counties', company: 'Everest Home Improvements' },
  { year: '2004',        role: 'Store Manager',                 company: 'Phones 4u' },
  { year: '2001 — 2004', role: 'Entertainer & DJ',              company: 'Potters Resort' },
];
---
<Layout
  title="About — AWJ"
  description="Andy Whyte. Founder/CEO of MEDDICC, best-selling author, MEDDPICC superfan. Why AWJ exists."
>
  {/* HERO */}
  <section class="ab-hero">
    <div class="site-shell ab-hero__inner">
      <div class="ab-hero__copy">
        <Eyebrow>Who is this?</Eyebrow>
        <h1 class="ab-hero__title">
          Andy Whyte. <Hl>Founder/CEO</Hl>, best-selling author, dad, human.
        </h1>
        <p class="ab-hero__lead">Outcome-oriented, results-driven. MEDDIC superfan.</p>
      </div>
      <div class="ab-hero__photo">
        <img
          src="/media/portrait/andy-leather-jacket.webp"
          alt="Andy Whyte — Founder and CEO of MEDDICC"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  {/* BIO — real text, in Andy's voice */}
  <section class="ab-bio">
    <div class="content-shell prose">
      <h2>From B-player to founder.</h2>
      <p>I'm the founder and CEO of MEDDICC, but before that, I spent 17 years as an individual contributor and sales leader.</p>
      <p>There was a time early in my career when I felt like no matter how much work I put in, I was playing sales on hard mode while everyone around me was playing it on easy mode.</p>
      <p>That was when I discovered MEDDIC and unlocked my full potential as a salesperson. It was like I went from a B-player version of myself to the A-player version.</p>
      <p>I realised that while the best organisations I knew all used MEDDIC, nobody was talking about it. I started to write about it, and quickly found a keen audience.</p>
      <p>Blog posts turned into a book, and the book turned into a bestseller.</p>
      <p>Today, MEDDICC has helped over <strong>100,000 people</strong> level up using MEDDPICC.</p>
    </div>
  </section>

  {/* CAREER JOURNEY — a path of milestones from origin to apex */}
  <section class="ab-journey">
    <div class="ab-journey__head">
      <Eyebrow>The long way round</Eyebrow>
      <h2 class="ab-journey__title">From entertainer to founder. <Hl>Twenty years.</Hl> One trajectory.</h2>
      <p class="ab-journey__lead">Every role taught me one thing about selling. Stack them up and you get MEDDICC.</p>
    </div>

    <div class="ab-journey__path">
      {/* APEX — present day */}
      <div class="jrn__apex">
        <div class="jrn__apex-flag">You are here</div>
        <span class="jrn__apex-pin" aria-hidden="true"></span>
        <div class="jrn__apex-year">2021 — present</div>
        <h3 class="jrn__apex-role">Founder &amp; CEO</h3>
        <div class="jrn__apex-company">MEDDICC</div>
        <p class="jrn__apex-note">Bootstrapping MEDDICC from a book into the operating system for enterprise GTM. 50+ A-players, 25,000+ MEDDPICC Masterclass graduates, customers including AWS, Cloudflare, CrowdStrike, Cisco, LinkedIn, Zapier.</p>
        <div class="jrn__apex-also">
          <span class="jrn__apex-also-eyebrow">Also</span>
          <div class="jrn__apex-also-line">
            <strong>Creative Director</strong> · MEDDICC MEDIA · 2022 — present
          </div>
        </div>
      </div>

      {/* PATH — alternating milestones */}
      <ol class="jrn__list" aria-label="Career milestones">
        {milestones.map((m, i) => (
          <li class={`jrn__item ${i % 2 === 0 ? 'jrn__item--left' : 'jrn__item--right'}`}>
            <span class="jrn__pin" aria-hidden="true"></span>
            <div class="jrn__card">
              <div class="jrn__card-year">{m.year}</div>
              <h3 class="jrn__card-role">{m.role}</h3>
              <div class="jrn__card-company">{m.company}</div>
            </div>
          </li>
        ))}
      </ol>

      {/* ORIGIN — start of the path */}
      <div class="jrn__origin">
        <span class="jrn__origin-pin" aria-hidden="true"></span>
        <div class="jrn__origin-label">Where it began</div>
        <p class="jrn__origin-note">Started selling fun on a Saturday night. Never stopped selling.</p>
      </div>
    </div>
  </section>

  {/* THREE PILLARS — the WHY for AWJ */}
  <section class="ab-pillars">
    <div class="content-shell prose">
      <h2>Why AWJ exists.</h2>
      <p>AWJ is a notebook page that earned the right to be on a billboard. It's the public form of the journal I've kept in private — applied thinking from someone who's done both the work and the worrying.</p>
      <p>Three pillars:</p>
      <p><strong>Sales — authority.</strong> MEDDICC, deal inspection, sales as a thinking discipline.</p>
      <p><strong>Founder — operator.</strong> Bootstrap SaaS, trade-offs under uncertainty, no theatre.</p>
      <p><strong>Human — truth.</strong> Controlled lessons from failure. The quality of your thinking determines the quality of your life.</p>
      <p>If that resonates, the journal arrives Fridays.</p>
    </div>
    <div class="ab-pillars__cta">
      <Btn href="/journal/" tone="dark">Read the archive</Btn>
      <Btn href="/subscribe/" tone="ghost">Subscribe</Btn>
    </div>
  </section>

  {/* SUBSCRIBE STRIP */}
  <section class="ab-sub awj-bg-paper-blue">
    <div class="site-shell ab-sub__inner">
      <Eyebrow color="#FFCE00">Frictionless</Eyebrow>
      <h2 class="ab-sub__h">One entry. <Hl>Every Friday.</Hl> No noise.</h2>
      <SubscribeForm tone="dark" />
    </div>
  </section>
</Layout>

<style>
  /* ---------------- HERO ---------------- */
  .ab-hero { padding: var(--sp-9) 0 var(--sp-7); border-bottom: var(--border-hard); }
  .ab-hero__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-7);
    align-items: center;
    padding: 0 var(--gutter);
  }
  @media (min-width: 900px) { .ab-hero__inner { grid-template-columns: 1.3fr 1fr; } }
  .ab-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    line-height: 0.95;
    font-size: clamp(40px, 6.5vw, 96px);
    margin: var(--sp-3) 0 var(--sp-5);
  }
  .ab-hero__lead {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    margin: 0;
    color: var(--fg-2);
  }
  /* New portrait container: 4:5 aspect, image cover-fitted but anchored to the
     top so the head is never the part that gets clipped. The leather-jacket
     portrait is naturally 2:3 — at 4:5 it crops only from the bottom. */
  .ab-hero__photo {
    border: var(--border-hard);
    background: var(--awj-yellow);
    background-image: url('/assets/textures/paper_yellow.png');
    background-size: cover;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    position: relative;
  }
  .ab-hero__photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    /* image is already monochrome — no extra grayscale filter needed */
  }

  /* ---------------- BIO ---------------- */
  .ab-bio { padding: var(--sp-8) 0 var(--sp-7); }
  .ab-bio .prose { padding: 0 var(--gutter); }

  /* ---------------- CAREER JOURNEY ---------------- */
  .ab-journey {
    padding: var(--sp-9) 0 var(--sp-9);
    border-top: var(--border-hard);
    background: var(--awj-paper);
    background-image: url('/assets/textures/paper_white.png');
    background-size: 600px;
    position: relative;
    overflow: hidden;
  }
  .ab-journey__head {
    max-width: var(--content-max);
    margin: 0 auto var(--sp-8);
    padding: 0 var(--gutter);
    text-align: left;
  }
  .ab-journey__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 0.95;
    letter-spacing: -0.005em;
    margin: var(--sp-3) 0 var(--sp-4);
  }
  .ab-journey__lead {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    color: var(--fg-2);
    margin: 0;
  }

  /* The path itself — vertical container with a centered dashed spine */
  .ab-journey__path {
    position: relative;
    max-width: 980px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .ab-journey__path::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 24px;
    bottom: 24px;
    width: 0;
    border-left: 2px dashed var(--awj-black);
    transform: translateX(-1px);
    z-index: 0;
  }

  /* APEX CARD — present day MEDDICC */
  .jrn__apex {
    position: relative;
    max-width: 560px;
    margin: 0 auto var(--sp-7);
    background: var(--awj-yellow);
    background-image: url('/assets/textures/paper_yellow.png');
    background-size: cover;
    border: var(--border-thicc);
    padding: var(--sp-6) var(--sp-6) var(--sp-6);
    box-shadow: var(--shadow-paper);
    z-index: 2;
  }
  .jrn__apex-flag {
    position: absolute;
    top: -14px;
    left: 24px;
    background: var(--awj-black);
    color: var(--awj-yellow);
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    transform: rotate(-2deg);
  }
  .jrn__apex-pin {
    position: absolute;
    left: 50%;
    bottom: -14px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--awj-black);
    border: 4px solid var(--awj-yellow);
    box-shadow: 0 0 0 2px var(--awj-black);
    transform: translateX(-50%);
    z-index: 3;
  }
  .jrn__apex-year {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--awj-black);
  }
  .jrn__apex-role {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(36px, 4.5vw, 56px);
    line-height: 0.95;
    margin: var(--sp-2) 0 var(--sp-1);
    color: var(--awj-black);
  }
  .jrn__apex-company {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 0.95;
    color: var(--awj-black);
  }
  .jrn__apex-note {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--awj-black);
    margin: var(--sp-4) 0 0;
  }
  .jrn__apex-also {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: 1.5px solid rgba(0,0,0,0.4);
  }
  .jrn__apex-also-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(0,0,0,0.7);
    margin-bottom: 4px;
  }
  .jrn__apex-also-line {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--awj-black);
  }

  /* MILESTONE LIST */
  .jrn__list {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .jrn__item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 64px 1fr;
    gap: 0;
    margin-bottom: var(--sp-6);
    align-items: start;
  }
  .jrn__pin {
    grid-column: 2;
    justify-self: center;
    margin-top: 22px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--awj-black);
    border: 3px solid var(--awj-paper);
    box-shadow: 0 0 0 2px var(--awj-black);
    z-index: 1;
  }
  .jrn__card {
    background: var(--awj-white);
    border: var(--border-hard);
    padding: var(--sp-4) var(--sp-5);
    box-shadow: var(--shadow-paper);
    position: relative;
    z-index: 1;
  }
  /* Connector line from card edge to spine */
  .jrn__card::after {
    content: '';
    position: absolute;
    top: 26px;
    width: 28px;
    border-top: 2px solid var(--awj-black);
  }
  .jrn__item--left  .jrn__card { grid-column: 1; }
  .jrn__item--left  .jrn__card::after { right: -28px; }
  .jrn__item--right .jrn__card { grid-column: 3; }
  .jrn__item--right .jrn__card::after { left: -28px; }

  .jrn__card-year {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-2);
  }
  .jrn__card-role {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(20px, 2.2vw, 28px);
    line-height: 0.95;
    margin: 6px 0 4px;
    color: var(--awj-black);
  }
  .jrn__card-company {
    font-family: var(--font-body);
    font-size: var(--fs-body);
    color: var(--fg-2);
  }

  /* ORIGIN — bottom of the path */
  .jrn__origin {
    position: relative;
    text-align: center;
    margin-top: var(--sp-5);
    padding-top: var(--sp-6);
  }
  .jrn__origin-pin {
    position: absolute;
    left: 50%;
    top: -2px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--awj-paper);
    border: 3px solid var(--awj-black);
    transform: translateX(-50%);
    z-index: 2;
  }
  .jrn__origin-label {
    font-family: var(--font-mono);
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-2);
    margin-bottom: var(--sp-2);
  }
  .jrn__origin-note {
    font-family: var(--font-marker);
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--awj-black);
    margin: 0;
    line-height: 1.1;
  }

  /* MOBILE — collapse to single column with spine on the left */
  @media (max-width: 760px) {
    .ab-journey__path::before {
      left: 22px;
      transform: none;
    }
    .jrn__apex {
      margin-left: 0;
      margin-right: 0;
    }
    .jrn__apex-pin {
      left: 22px;
    }
    .jrn__item {
      grid-template-columns: 44px 1fr;
    }
    .jrn__pin {
      grid-column: 1;
      justify-self: start;
      margin-left: 14px;
    }
    .jrn__item--left  .jrn__card,
    .jrn__item--right .jrn__card {
      grid-column: 2;
    }
    .jrn__item--left  .jrn__card::after,
    .jrn__item--right .jrn__card::after {
      left: -16px;
      right: auto;
      width: 16px;
    }
    .jrn__origin {
      text-align: left;
      padding-left: 22px;
    }
    .jrn__origin-pin {
      left: 22px;
      transform: translateX(-50%);
    }
  }

  /* ---------------- PILLARS ---------------- */
  .ab-pillars { padding: var(--sp-8) 0 var(--sp-9); border-top: var(--border-hard); }
  .ab-pillars .prose { padding: 0 var(--gutter); }
  .ab-pillars__cta {
    margin-top: var(--sp-7);
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    padding: 0 var(--gutter);
    max-width: var(--content-max);
    margin-left: auto;
    margin-right: auto;
  }

  /* ---------------- SUBSCRIBE STRIP ---------------- */
  .ab-sub { position: relative; overflow: hidden; }
  .ab-sub__inner { padding: var(--sp-9) var(--gutter); position: relative; max-width: var(--site-max); margin: 0 auto; }
  .ab-sub__h {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(40px, 7vw, 96px);
    line-height: 1;
    margin: var(--sp-3) 0 var(--sp-6);
    color: var(--awj-white);
    max-width: 18ch;
  }
</style>
