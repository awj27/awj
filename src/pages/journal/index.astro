---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Pillar from '../../components/Pillar.astro';
import { getCollection } from 'astro:content';
import { formatDate, type Pillar as PillarT, PILLAR_META } from '../../lib/utils';

const all = (await getCollection('journal', e => !e.data.draft))
  .sort((a, b) => b.data.awj_number - a.data.awj_number);
---
<Layout
  title="The Journal — AWJ"
  description="Every Maxim, every essay. Filterable by pillar."
>
  <section class="archive-hero">
    <div class="site-shell">
      <Eyebrow>The archive</Eyebrow>
      <h1 class="archive-hero__title awj-display">The Journal.</h1>
      <p class="archive-hero__sub">{all.length} entries. One a Friday. No noise.</p>
    </div>
  </section>

  <section class="archive">
    <div class="site-shell">
      <nav class="archive__filters" aria-label="Filter by pillar">
        <a href="/journal/" class="is-active">All</a>
        {(['sales', 'founder', 'human'] as PillarT[]).map(p => (
          <a href={`/pillars/${p}/`}>{PILLAR_META[p].label}</a>
        ))}
      </nav>
      <ol class="archive__list">
        {all.map(e => (
          <li>
            <a href={`/journal/${e.data.slug ?? e.id}/`} class="archive__row">
              <span class="archive__num">AWJ #{e.data.awj_number}</span>
              <span class="archive__title awj-display">{e.data.title}</span>
              <span class="archive__pillar"><Pillar pillar={e.data.pillar} /></span>
              <time class="archive__date" datetime={e.data.date.toISOString()}>{formatDate(e.data.date)}</time>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
</Layout>

<style>
  .archive-hero { padding: var(--sp-9) 0 var(--sp-5); border-bottom: 1px solid var(--rule); }
  .archive-hero__title { font-size: clamp(56px, 9vw, 144px); margin: var(--sp-3) 0; }
  .archive-hero__sub { font-size: var(--fs-body-lg); color: var(--fg-2); margin: 0; }

  .archive { padding: var(--sp-7) 0 var(--sp-9); }
  .archive__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
  }
  .archive__filters a {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 8px 14px;
    border: var(--border-hard);
    color: var(--awj-black);
    background: var(--awj-white);
    border-radius: var(--radius-pill);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .archive__filters a:hover { background: var(--awj-yellow); }
  .archive__filters a.is-active { background: var(--awj-black); color: var(--awj-white); }

  .archive__list { list-style: none; padding: 0; margin: 0; }
  .archive__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-2);
    padding: var(--sp-5) 0;
    border-bottom: 1px solid var(--rule);
    color: var(--awj-black);
    text-decoration: none;
    transition: background var(--t-fast);
  }
  @media (min-width: 720px) {
    .archive__row {
      grid-template-columns: 80px 1fr 110px 110px;
      align-items: center;
      gap: var(--sp-4);
    }
  }
  .archive__row:hover { background: rgba(255,206,0,0.12); }
  .archive__num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--fg-2);
  }
  .archive__title {
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.05;
    overflow-wrap: anywhere;
  }
  .archive__date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-2);
  }
</style>
