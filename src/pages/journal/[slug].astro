---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Btn from '../../components/Btn.astro';
import Pillar from '../../components/Pillar.astro';
import Scribble from '../../components/Scribble.astro';
import Signature from '../../components/Signature.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { getCollection, render } from 'astro:content';
import { formatIssueDate, readingTime, PILLAR_META } from '../../lib/utils';

export async function getStaticPaths() {
  const entries = await getCollection('journal', e => !e.data.draft);
  return entries.map(entry => ({
    params: { slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const issue = formatIssueDate(entry.data.modified ?? entry.data.date);
const rt = readingTime(entry.body ?? '');

// Build a clean meta description: strip HTML tags + collapse whitespace
// before slicing. Without this, raw markup from any inline HTML in the
// markdown body (e.g. the hero-script div) leaks into <meta description>.
const plainBody = (entry.body ?? '')
  .replace(/<!--([\s\S]*?)-->/g, ' ')
  .replace(/<[^>]+>/g, ' ')
  .replace(/&[a-z]+;|&#\d+;/gi, ' ')
  .replace(/\s+/g, ' ')
  .trim();
const metaDescription = plainBody.length > 160
  ? plainBody.slice(0, 157).trimEnd() + '…'
  : (plainBody || entry.data.title);

// "Read next" — pick up to 3 sibling essays from the same pillar, then top up
// from the rest of the journal if the pillar is thin. Excludes the current
// entry. Surfaces editorial cluster context for both readers and crawlers.
const allEntries = (await getCollection('journal', e => !e.data.draft))
  .filter(e => e.id !== entry.id)
  .sort((a, b) => b.data.awj_number - a.data.awj_number);
const samePillar = allEntries.filter(e => e.data.pillar === entry.data.pillar);
const otherPillars = allEntries.filter(e => e.data.pillar !== entry.data.pillar);
const readNext = [...samePillar, ...otherPillars].slice(0, 3);
const pillarLabel = PILLAR_META[entry.data.pillar].label;
---
<Layout
  title={`${entry.data.title}: ${pillarLabel} | Andy Whyte Journal`}
  description={metaDescription}
  ogImage={`/media/awj${entry.data.awj_number}.webp`}
  pillar={entry.data.pillar}
  awjNumber={entry.data.awj_number}
  pageType="maxim"
>
  <article>
    {/* Header band */}
    <section class="entry__band">
      <div class="site-shell entry__band-inner">
        <a href="/journal/" class="entry__back">← Journal</a>
        <div class="entry__meta">
          <Pillar pillar={entry.data.pillar} />
          <span class="awj-meta">Issue {String(entry.data.awj_number).padStart(3, '0')} · {rt} · {issue}</span>
        </div>
      </div>
    </section>

    {/* Headline */}
    <section class="entry__hero">
      <div class="site-shell entry__hero-inner">
        <h1 class="entry__title awj-billboard">{entry.data.title}</h1>
        <Scribble src="/assets/scribbles/scribble_fire_2.png" rotate={8} top="40px" right="4%" width={140} />
      </div>
    </section>

    {/* Video — hero asset */}
    {entry.data.video_id && (
      <section class="entry__video">
        <div class="site-shell">
          <div class="entry__video-frame">
            <iframe
              id={`maxim-video-${entry.data.awj_number}`}
              src={`https://www.youtube-nocookie.com/embed/${entry.data.video_id}`}
              title={`${entry.data.title} — video`}
              loading="lazy"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              data-yt-track
              data-yt-title={entry.data.title}
              data-yt-type="longform"
            ></iframe>
          </div>
        </div>
      </section>
    )}

    {/* Body */}
    <section class="entry__body">
      <div class="content-shell prose">
        <Content />
      </div>
    </section>

    {/* About the author — anchors authorship for readers and search/AI engines. */}
    <section class="entry__author">
      <div class="content-shell">
        <AuthorBio />
      </div>
    </section>

    {/* Read next — 3 sibling essays. Internal-link signal + reader retention. */}
    {readNext.length > 0 && (
      <section class="entry__readnext">
        <div class="content-shell">
          <Eyebrow>Read next</Eyebrow>
          <ul class="entry__readnext-grid">
            {readNext.map(e => (
              <li class="entry__readnext-card">
                <a href={`/journal/${e.data.slug ?? e.id}/`} class="entry__readnext-link">
                  <span class="entry__readnext-meta">
                    AWJ #{String(e.data.awj_number).padStart(2, '0')}
                    <span aria-hidden="true"> · </span>
                    <span class="entry__readnext-pillar">{PILLAR_META[e.data.pillar].label}</span>
                  </span>
                  <span class="entry__readnext-title awj-display">{e.data.title}</span>
                  <span class="entry__readnext-cta">Read →</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    {/* Sign-off + CTA */}
    <section class="entry__signoff">
      <div class="content-shell entry__signoff-inner">
        <Signature size={48} />
        <Btn href="/subscribe/" tone="dark">Subscribe to the journal →</Btn>
      </div>
    </section>

    {/* Subscribe block */}
    <section class="entry__sub awj-bg-paper-blue">
      <div class="site-shell entry__sub-inner">
        <Eyebrow color="#FFCE00">Keep reading</Eyebrow>
        <h2 class="entry__sub-title awj-display">One entry. Every Friday.</h2>
        <SubscribeForm tone="dark" />
      </div>
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Article',
        '@id': `${Astro.url.toString()}#article`,
        headline: entry.data.title,
        datePublished: entry.data.date.toISOString?.() ?? String(entry.data.date),
        dateModified: (entry.data.modified ?? entry.data.date).toISOString?.() ?? String(entry.data.modified ?? entry.data.date),
        author: { '@id': 'https://andywhyte.com/#andy' },
        publisher: { '@id': 'https://andywhyte.com/#org' },
        mainEntityOfPage: Astro.url.toString(),
        image: `https://andywhyte.com/media/awj${entry.data.awj_number}.webp`,
        articleSection: PILLAR_META[entry.data.pillar].label,
        inLanguage: 'en-GB',
        ...(entry.data.video_id && {
          video: {
            '@type': 'VideoObject',
            name: entry.data.title,
            thumbnailUrl: `https://i.ytimg.com/vi/${entry.data.video_id}/maxresdefault.jpg`,
            embedUrl: `https://www.youtube-nocookie.com/embed/${entry.data.video_id}`,
            uploadDate: entry.data.date.toISOString?.() ?? String(entry.data.date),
          },
        }),
      },
      {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://andywhyte.com/' },
          { '@type': 'ListItem', position: 2, name: 'Journal', item: 'https://andywhyte.com/journal/' },
          { '@type': 'ListItem', position: 3, name: PILLAR_META[entry.data.pillar].label, item: `https://andywhyte.com/pillars/${entry.data.pillar}/` },
          { '@type': 'ListItem', position: 4, name: entry.data.title, item: Astro.url.toString() },
        ],
      },
    ],
  })} />
</Layout>

<style>
  .entry__band {
    padding: var(--sp-7) 0 var(--sp-4);
    border-bottom: 1px solid var(--rule);
  }
  .entry__band-inner { display: flex; flex-direction: column; gap: var(--sp-4); }
  .entry__back {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--awj-black);
  }
  .entry__meta { display: flex; flex-wrap: wrap; align-items: center; gap: var(--sp-3); }

  .entry__hero { padding: var(--sp-7) 0 var(--sp-5); position: relative; overflow: hidden; }
  .entry__hero-inner { position: relative; }
  .entry__title { max-width: 1100px; }

  .entry__video { padding: var(--sp-3) 0 var(--sp-7); }
  .entry__video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--awj-black);
    border: var(--border-thicc);
    overflow: hidden;
    box-shadow: 12px 12px 0 var(--awj-yellow);
  }
  .entry__video-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  @media (max-width: 720px) {
    .entry__video-frame { box-shadow: 6px 6px 0 var(--awj-yellow); }
  }

  .entry__body { padding: var(--sp-4) 0 var(--sp-5); }
  .entry__author { padding: 0 0 var(--sp-7); }

  .entry__readnext {
    padding: var(--sp-7) 0 var(--sp-8);
    border-top: var(--border-hard);
    background: var(--awj-paper);
    background-image: url('/assets/textures/paper_white.png');
    background-size: cover;
  }
  .entry__readnext-grid {
    list-style: none;
    padding: 0;
    margin: var(--sp-4) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }
  @media (min-width: 720px) {
    .entry__readnext-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .entry__readnext-card {
    border: var(--border-hard);
    background: var(--awj-white);
    transition: transform var(--t-fast), box-shadow var(--t-fast);
  }
  .entry__readnext-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--awj-black);
  }
  .entry__readnext-link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    padding: var(--sp-5);
    text-decoration: none;
    color: var(--awj-black);
    height: 100%;
  }
  .entry__readnext-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-2);
  }
  .entry__readnext-pillar { color: var(--awj-blue); font-weight: 700; }
  .entry__readnext-title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.05;
    letter-spacing: -0.005em;
    overflow-wrap: anywhere;
    flex: 1;
  }
  .entry__readnext-cta {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: auto;
  }

  .entry__signoff {
    padding: var(--sp-5) 0;
    border-top: var(--border-hard);
  }
  .entry__signoff-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    flex-wrap: wrap;
  }
  .entry__sub-inner { padding: var(--sp-9) 0; position: relative; }
  .entry__sub-title {
    font-size: clamp(40px, 6vw, 88px);
    line-height: 1;
    margin: var(--sp-3) 0 var(--sp-6);
    color: var(--awj-white);
  }
</style>
