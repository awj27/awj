<script>
  // Long-form cinema player + pillar filter
  (() => {
    const iframe = document.getElementById('cinema-iframe') as HTMLIFrameElement | null;
    const titleEl = document.getElementById('cinema-title');
    const pillarEl = document.getElementById('cinema-pillar');
    const ytLink = document.getElementById('cinema-yt-link') as HTMLAnchorElement | null;
    const thumbs = document.querySelectorAll<HTMLLIElement>('.cinema__thumb');
    const filters = document.querySelectorAll<HTMLButtonElement>('.cinema__filter');

    thumbs.forEach(thumb => {
      const btn = thumb.querySelector<HTMLButtonElement>('.cinema__thumb-btn');
      btn?.addEventListener('click', () => {
        const id = thumb.dataset.videoId!;
        if (iframe) iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
        if (titleEl) titleEl.textContent = thumb.dataset.title ?? '';
        if (pillarEl) {
          pillarEl.textContent = thumb.dataset.pillarLabel ?? '';
          pillarEl.dataset.pillar = thumb.dataset.pillar ?? '';
        }
        if (ytLink)  ytLink.href = `https://www.youtube.com/watch?v=${id}`;
        thumbs.forEach(t => t.classList.remove('is-active'));
        thumb.classList.add('is-active');
        document.querySelector('.cinema__player')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    filters.forEach(filter => {
      filter.addEventListener('click', () => {
        const f = filter.dataset.filter!;
        filters.forEach(x => x.classList.remove('is-active'));
        filter.classList.add('is-active');
        thumbs.forEach(thumb => {
          if (f === 'all' || thumb.dataset.pillar === f) thumb.removeAttribute('hidden');
          else thumb.setAttribute('hidden', '');
        });
      });
    });
  })();

  // Shorts player + pillar filter
  (() => {
    const iframe = document.getElementById('shorts-iframe') as HTMLIFrameElement | null;
    const titleEl = document.getElementById('shorts-title');
    const pillarEl = document.getElementById('shorts-pillar');
    const ytLink = document.getElementById('shorts-yt-link') as HTMLAnchorElement | null;
    const thumbs = document.querySelectorAll<HTMLLIElement>('.shorts__thumb');
    const filters = document.querySelectorAll<HTMLButtonElement>('.shorts__filter');

    thumbs.forEach(thumb => {
      const btn = thumb.querySelector<HTMLButtonElement>('.shorts__thumb-btn');
      btn?.addEventListener('click', () => {
        const id = thumb.dataset.videoId!;
        if (iframe) iframe.src = `https://www.youtube-nocookie.com/embed/${id}?rel=0&modestbranding=1&autoplay=1`;
        if (titleEl) titleEl.textContent = thumb.dataset.title ?? '';
        if (pillarEl) {
          pillarEl.textContent = thumb.dataset.pillarLabel ?? '';
          pillarEl.dataset.pillar = thumb.dataset.pillar ?? '';
        }
        if (ytLink)  ytLink.href = `https://www.youtube.com/shorts/${id}`;
        thumbs.forEach(t => t.classList.remove('is-active'));
        thumb.classList.add('is-active');
        document.querySelector('.shorts__player')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    filters.forEach(filter => {
      filter.addEventListener('click', () => {
        const f = filter.dataset.filter!;
        filters.forEach(x => x.classList.remove('is-active'));
        filter.classList.add('is-active');
        thumbs.forEach(thumb => {
          if (f === 'all' || thumb.dataset.pillar === f) thumb.removeAttribute('hidden');
          else thumb.setAttribute('hidden', '');
        });
      });
    });
  })();
</script>
