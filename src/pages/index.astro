---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Btn from '../components/Btn.astro';
import Hl from '../components/Hl.astro';
import Pillar from '../components/Pillar.astro';
import Scribble from '../components/Scribble.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import { getCollection } from 'astro:content';
import { PILLAR_META, formatIssueDate, type Pillar as PillarT } from '../lib/utils';

const all = (await getCollection('journal', e => !e.data.draft))
  .sort((a, b) => b.data.awj_number - a.data.awj_number);

const featured = all.find(e => e.data.awj_number === 1) ?? all[0];
const recent = all.filter(e => e.id !== featured.id).slice(0, 4);
const issueDate = formatIssueDate(featured.data.modified ?? featured.data.date);
---
<Layout
  title="AWJ — Andy Whyte Journal"
  description="A notebook page that earned the right to be on a billboard. Maxims and essays from Andy Whyte across sales, founding, and being human. One entry every Friday. No noise."
>
  {/* HERO — black paper, portrait blends in from the right */}
  <section class="hero">
    {/* Background layers: paper texture + portrait + dark gradient blend */}
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/media/portrait/andy-portrait.jpg"
        srcset="/media/portrait/andy-portrait-mobile.jpg 800w, /media/portrait/andy-portrait.jpg 1600w"
        sizes="100vw"
        alt=""
        class="hero__bg-portrait"
      />
      <div class="hero__bg-fade"></div>
    </div>

    <div class="site-shell hero__inner">
      <Eyebrow color="#FFCE00">Issue {String(featured.data.awj_number).padStart(3, '0')} · Filed {issueDate}</Eyebrow>
      <h1 class="hero__title awj-billboard">
        {(() => {
          const t = featured.data.title;
          const m = t.match(/(uncomfortable)/i);
          if (!m) return t;
          const idx = m.index!;
          return [t.slice(0, idx), <Hl>{m[0]}</Hl>, t.slice(idx + m[0].length)];
        })()}
      </h1>
      <Scribble src="/assets/scribbles/underline_yellow.png" left="0" bottom="-10px" width={280} opacity={0.9} />
      <div class="hero__actions">
        <Btn href={`/journal/${featured.data.slug ?? featured.id}/`} tone="yellow">Read the entry</Btn>
        <Btn href="/journal/" tone="ghost">The archive</Btn>
      </div>
    </div>
  </section>

  {/* PILLARS */}
  <section class="pillars">
    <div class="site-shell">
      <Eyebrow>Three pillars</Eyebrow>
      <div class="pillars__grid">
        {(['sales', 'founder', 'human'] as PillarT[]).map((p, i) => {
          const meta = PILLAR_META[p];
          return (
            <a href={`/pillars/${p}/`} class={`pillars__card pillars__card--${p}`} style={`background-color: ${meta.bg}; color: ${meta.fg}`}>
              <span class="pillars__num">{String(i + 1).padStart(2, '0')} · {meta.tag.toUpperCase()}</span>
              <div>
                <h3 class="pillars__name">{meta.label}</h3>
                <p class="pillars__blurb">{meta.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {/* RECENT */}
  <section class="recent">
    <div class="site-shell">
      <div class="recent__head">
        <h2 class="recent__h">Recent entries</h2>
        <a href="/journal/" class="recent__archive-link">Full archive →</a>
      </div>
      <div class="recent__grid">
        {recent.map(e => (
          <article class="recent__card">
            <div class="recent__row">
              <Pillar pillar={e.data.pillar} />
              <span class="awj-meta">AWJ #{e.data.awj_number}</span>
            </div>
            <h3 class="recent__title">
              <a href={`/journal/${e.data.slug ?? e.id}/`}>{e.data.title}</a>
            </h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="cta awj-bg-paper-blue">
    <div class="site-shell cta__inner">
      <Scribble src="/assets/scribbles/pen_star_yellow.png" rotate={14} top="30px" right="8%" width={120} />
      <Eyebrow color="#FFCE00">The frictionless path</Eyebrow>
      <h2 class="cta__title">
        One entry. <Hl>Every Friday.</Hl> No noise.
      </h2>
      <SubscribeForm tone="dark" />
    </div>
  </section>
</Layout>

<style>
  /* HERO — black paper with portrait bleeding in from the right */
  .hero {
    position: relative;
    background-color: var(--awj-black);
    background-image: url('/assets/textures/paper_black.png');
    background-size: cover;
    background-position: center;
    color: var(--awj-white);
    border-bottom: var(--border-hard);
    overflow: hidden;
    min-height: 580px;
  }

  /* Background composition: portrait + dark gradient that blends it into the paper */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .hero__bg-portrait {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: 70% 18%;     /* shows Andy's face/upper body */
    filter: grayscale(1) contrast(1.05) brightness(0.95);
    /* Soft mask so the photo's left edge fades into the paper */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 18%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.95) 70%, black 100%);
            mask-image: linear-gradient(to right, transparent 0%, transparent 18%, rgba(0,0,0,0.35) 35%, rgba(0,0,0,0.95) 70%, black 100%);
  }
  /* Extra darken on the left so text always wins for legibility */
  .hero__bg-fade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right,
        rgba(10,10,10,0.96) 0%,
        rgba(10,10,10,0.85) 30%,
        rgba(10,10,10,0.45) 55%,
        rgba(10,10,10,0.0)  80%);
  }

  /* Mobile: photo is much less prominent; let text dominate */
  @media (max-width: 720px) {
    .hero__bg-portrait { object-position: 65% 12%; opacity: 0.55; }
    .hero__bg-fade {
      background:
        linear-gradient(to bottom,
          rgba(10,10,10,0.55) 0%,
          rgba(10,10,10,0.85) 60%,
          rgba(10,10,10,0.96) 100%);
    }
  }

  .hero__inner {
    position: relative;
    z-index: 1;
    padding: var(--sp-9) var(--gutter) var(--sp-8);
    max-width: var(--site-max);
    margin: 0 auto;
  }
  .hero__title {
    margin-top: var(--sp-4);
    margin-bottom: var(--sp-7);
    color: var(--awj-white);
    /* Constrain text width on wide screens so the portrait gets room to breathe */
    max-width: 90%;
  }
  @media (min-width: 1100px) {
    .hero__title { max-width: 64%; }
  }
  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--sp-3); }

  /* PILLARS */
  .pillars { padding: var(--sp-8) 0; border-bottom: var(--border-hard); }
  .pillars__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: var(--border-hard);
    background: var(--bg-2);
    margin-top: var(--sp-4);
  }
  @media (min-width: 720px) { .pillars__grid { grid-template-columns: repeat(3, 1fr); } }
  .pillars__card {
    padding: var(--sp-6);
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    border-bottom: var(--border-hard);
    background-size: cover; background-position: center;
    transition: transform var(--t-fast);
  }
  .pillars__card--sales   { background-image: url('/assets/textures/paper_yellow.png'); }
  .pillars__card--founder { background-image: url('/assets/textures/paper_blue.png');   }
  .pillars__card--human   { background-image: url('/assets/textures/paper_black.png');  }
  .pillars__card:hover { transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--awj-black); }
  .pillars__card:last-child { border-bottom: none; }
  @media (min-width: 720px) {
    .pillars__card { border-bottom: none; border-right: var(--border-hard); }
    .pillars__card:last-child { border-right: none; }
  }
  .pillars__num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    opacity: 0.85;
    color: inherit;
  }
  .pillars__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(48px, 5vw, 88px);
    line-height: 0.95;
    margin: 0 0 var(--sp-3);
    overflow-wrap: anywhere;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    color: inherit;
  }
  .pillars__blurb { font-size: 15px; line-height: 1.5; margin: 0; max-width: 320px; color: inherit; opacity: 0.92; }

  /* RECENT */
  .recent { padding: var(--sp-8) 0; border-bottom: var(--border-hard); }
  .recent__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
    flex-wrap: wrap;
  }
  .recent__h {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    font-size: clamp(32px, 4.5vw, 56px);
    margin: 0;
    line-height: 1;
  }
  .recent__archive-link {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--awj-black);
  }
  .recent__grid {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--rule);
  }
  @media (min-width: 720px) { .recent__grid { grid-template-columns: 1fr 1fr; } }
  .recent__card {
    padding: var(--sp-5) var(--sp-4);
    border-bottom: 1px solid var(--rule);
    color: var(--awj-black);
    transition: background var(--t-fast);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .recent__card:hover { background: rgba(255,206,0,0.12); }
  @media (min-width: 720px) { .recent__card:nth-child(odd) { border-right: 1px solid var(--rule); } }
  .recent__row { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-3); flex-wrap: wrap; }
  .recent__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(24px, 3.4vw, 40px);
    line-height: 1.02;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    overflow-wrap: anywhere;
  }
  .recent__title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(to bottom, transparent 88%, var(--awj-black) 88%, var(--awj-black) 95%, transparent 95%);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    transition: background-size var(--t-base) var(--ease-out);
  }
  .recent__title a:hover { background-size: 100% 100%; }

  /* CTA */
  .cta { position: relative; overflow: hidden; }
  .cta__inner { padding: var(--sp-9) var(--gutter); position: relative; }
  .cta__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    font-size: clamp(40px, 7vw, 96px);
    line-height: 1;
    margin: var(--sp-3) 0 var(--sp-6);
    max-width: 18ch;
    color: var(--awj-white);
  }
  .cta .awj-eyebrow { color: var(--awj-yellow); }
</style>
