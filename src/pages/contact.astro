---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Hl from '../components/Hl.astro';
import SocialIcons from '../components/SocialIcons.astro';
import Scribble from '../components/Scribble.astro';

// Topic prefilled from query string (e.g., /contact/?topic=speaking)
const topic = Astro.url.searchParams.get('topic') ?? '';
const topics = ['General', 'Speaking / SKO', 'Advisory', 'Press', 'Book', 'Other'];
const initialTopic = topics.find(t => t.toLowerCase().includes(topic.toLowerCase())) ?? 'General';
---
<Layout
  title="Contact — AWJ"
  description="Speaking, advisory, press, or just a hello. Get in touch with Andy Whyte."
  pageType="contact"
>
  {/* HERO */}
  <section class="ct-hero">
    <div class="site-shell ct-hero__inner">
      <Scribble src="/assets/scribbles/pen_star_yellow.png" rotate={14} top="40px" right="6%" width={120} />
      <Eyebrow>Get in touch</Eyebrow>
      <h1 class="ct-hero__title">
        Say <Hl>hello</Hl>.
      </h1>
      <p class="ct-hero__sub">Speaking, advisory, press, or just a hello. I read everything that comes through this form.</p>
    </div>
  </section>

  {/* MAIN GRID — form + social */}
  <section class="ct-main">
    <div class="site-shell ct-main__inner">
      {/* FORM */}
      <form class="ct-form" id="ct-form" novalidate>
        {/* Honeypot — hidden from users; bots auto-fill it and we reject */}
        <div aria-hidden="true" style="position:absolute; left:-9999px; opacity:0; pointer-events:none; height:0; overflow:hidden;">
          <label>Don't fill this in if you're human: <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>

        <label class="ct-field">
          <span>Your name</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>

        <label class="ct-field">
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>

        <label class="ct-field">
          <span>Topic</span>
          <select name="topic">
            {topics.map(t => (
              <option value={t} selected={t === initialTopic}>{t}</option>
            ))}
          </select>
        </label>

        <label class="ct-field">
          <span>Message</span>
          <textarea name="message" rows="6" required minlength="10"></textarea>
        </label>

        <button class="ct-form__btn" type="submit" id="ct-submit">Send →</button>
        <p class="ct-form__msg" id="ct-msg" aria-live="polite"></p>
      </form>

      {/* SOCIAL + DIRECT */}
      <aside class="ct-side">
        <div class="ct-side__block">
          <Eyebrow>Or find me on</Eyebrow>
          <div class="ct-side__socials">
            <SocialIcons tone="dark" size={28} />
          </div>
        </div>

        <div class="ct-side__block">
          <Eyebrow>Direct</Eyebrow>
          <p class="ct-side__direct">
            Email <a href="mailto:hello@andywhyte.com">hello@andywhyte.com</a> if you'd rather skip the form.
          </p>
        </div>

        <div class="ct-side__block ct-side__note">
          <p><strong>For speaking enquiries:</strong> include the event date, location, audience size, and budget if you have one. Saves a round of email tag.</p>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .ct-hero {
    padding: var(--sp-9) 0 var(--sp-7);
    border-bottom: var(--border-hard);
    position: relative;
    overflow: hidden;
  }
  .ct-hero__inner { padding: 0 var(--gutter); position: relative; }
  .ct-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    font-size: clamp(56px, 9vw, 144px);
    margin: var(--sp-3) 0;
    line-height: 0.95;
  }
  .ct-hero__sub { font-size: var(--fs-body-lg); color: var(--fg-2); margin: 0; max-width: 60ch; }

  .ct-main { padding: var(--sp-8) 0 var(--sp-9); }
  .ct-main__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-7);
    padding: 0 var(--gutter);
  }
  @media (min-width: 900px) {
    .ct-main__inner { grid-template-columns: 1.6fr 1fr; gap: var(--sp-8); }
  }

  .ct-form { display: grid; gap: var(--sp-5); position: relative; }
  .ct-field { display: flex; flex-direction: column; gap: var(--sp-2); }
  .ct-field span {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .ct-field input, .ct-field select, .ct-field textarea {
    font-family: var(--font-body);
    font-size: 16px;
    padding: 14px 16px;
    background: var(--awj-white);
    color: var(--awj-black);
    border: var(--border-hard);
    border-radius: 0;
  }
  .ct-field textarea { resize: vertical; min-height: 140px; }
  .ct-field input:focus, .ct-field select:focus, .ct-field textarea:focus {
    outline: 2px solid var(--awj-yellow);
    outline-offset: -4px;
  }

  .ct-form__btn {
    justify-self: start;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 16px 28px;
    background: var(--awj-black);
    color: var(--awj-white);
    border: var(--border-hard);
    cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast);
  }
  .ct-form__btn:hover { background: var(--awj-yellow); color: var(--awj-black); }
  .ct-form__btn:disabled { opacity: 0.6; cursor: wait; }
  .ct-form__msg { font-size: 14px; margin: 0; min-height: 1.4em; }
  .ct-form__msg[data-state='success'] { color: var(--awj-blue); font-weight: 700; }
  .ct-form__msg[data-state='error']   { color: var(--awj-red); font-weight: 700; }

  .ct-side { display: flex; flex-direction: column; gap: var(--sp-7); }
  .ct-side__block .awj-eyebrow { margin-bottom: var(--sp-3); }
  .ct-side__socials { margin-top: var(--sp-2); }
  .ct-side__direct { font-size: var(--fs-body); margin: 0; }
  .ct-side__direct a {
    background-image: linear-gradient(transparent 80%, var(--awj-yellow) 80%, var(--awj-yellow) 95%, transparent 95%);
    background-repeat: no-repeat;
    color: var(--awj-black);
  }
  .ct-side__note {
    background: var(--awj-yellow);
    background-image: url('/assets/textures/paper_yellow.png');
    background-size: cover;
    padding: var(--sp-5);
    border: var(--border-hard);
    transform: rotate(-1deg);
  }
  .ct-side__note p { margin: 0; font-size: 14px; line-height: 1.55; }
  .ct-side__note strong { font-weight: 800; }
</style>

<script>
  // Form posts to /api/contact — a Cloudflare Pages Function that emails
  // hello@andywhyte.com via Resend. See functions/api/contact.ts for the
  // server logic and required env vars.
  const form = document.getElementById('ct-form') as HTMLFormElement | null;
  const msg = document.getElementById('ct-msg') as HTMLElement | null;
  const btn = document.getElementById('ct-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async e => {
    e.preventDefault();
    if (!form || !msg || !btn) return;

    const fd = new FormData(form);

    // Honeypot — server also enforces, but short-circuit here too
    if (fd.get('website')) {
      msg.dataset.state = 'success';
      msg.textContent = 'Thanks — your message is on its way.';
      form.reset();
      return;
    }

    const payload = {
      name:    String(fd.get('name')    ?? '').trim(),
      email:   String(fd.get('email')   ?? '').trim(),
      topic:   String(fd.get('topic')   ?? 'General').trim(),
      message: String(fd.get('message') ?? '').trim(),
    };

    if (!payload.name || !payload.email.includes('@') || payload.message.length < 10) {
      msg.dataset.state = 'error';
      msg.textContent = 'Please fill all fields and write at least 10 characters.';
      return;
    }

    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (data.ok) {
        msg.dataset.state = 'success';
        msg.textContent = data.message ?? "Thanks — your message is on its way.";
        form.reset();
        btn.textContent = 'Sent ✓';
        return;
      }
      msg.dataset.state = 'error';
      msg.textContent = data.error ?? 'Send failed. Try emailing hello@andywhyte.com directly.';
      btn.disabled = false;
      btn.textContent = original ?? 'Send →';
    } catch {
      msg.dataset.state = 'error';
      msg.textContent = 'Network error. Try again or email hello@andywhyte.com.';
      btn.disabled = false;
      btn.textContent = original ?? 'Send →';
    }
  });
</script>
