---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Pillar from '../../components/Pillar.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('journal', e => !e.data.draft))
  .sort((a, b) => b.data.awj_number - a.data.awj_number);
---
<Layout
  title="Maxims — AWJ"
  description="The wall of Maxims. The lines. Built for sharing."
>
  <section class="mx-hero">
    <div class="site-shell">
      <Eyebrow>The wall</Eyebrow>
      <h1 class="mx-hero__title awj-display">Maxims.</h1>
      <p class="mx-hero__sub">{all.length} principles. Click any line to read the entry.</p>
    </div>
  </section>

  <section class="mx-grid">
    <div class="site-shell">
      <div class="mx-grid__cards">
        {all.map((e, i) => {
          const tones = ['white', 'yellow', 'blue', 'black'];
          const tone = tones[i % tones.length];
          return (
            <a href={`/journal/${e.data.slug ?? e.id}/`} class={`mx-card mx-card--${tone}`}>
              <span class="mx-card__num">AWJ #{e.data.awj_number}</span>
              <p class="mx-card__line awj-display">{e.data.title}</p>
              <span class="mx-card__pillar"><Pillar pillar={e.data.pillar} /></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>

<style>
  .mx-hero { padding: var(--sp-9) 0 var(--sp-5); border-bottom: var(--border-hard); }
  .mx-hero__title { font-size: clamp(56px, 9vw, 144px); margin: var(--sp-3) 0; }
  .mx-hero__sub { font-size: var(--fs-body-lg); color: var(--fg-2); margin: 0; }

  .mx-grid { padding: var(--sp-7) 0 var(--sp-9); }
  .mx-grid__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
  }
  @media (min-width: 720px) {
    .mx-grid__cards { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1100px) {
    .mx-grid__cards { grid-template-columns: 1fr 1fr 1fr; }
  }
  .mx-card {
    padding: var(--sp-6);
    border: var(--border-hard);
    text-decoration: none;
    color: var(--awj-black);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    min-height: 280px;
    transition: transform var(--t-fast);
    background-size: cover;
    background-position: center;
  }
  .mx-card:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--awj-black); }
  .mx-card--white  { background-color: var(--awj-white); background-image: url('/assets/textures/paper_white.png'); }
  .mx-card--yellow { background-color: var(--awj-yellow); background-image: url('/assets/textures/paper_yellow.png'); }
  .mx-card--blue   { background-color: var(--awj-blue); background-image: url('/assets/textures/paper_blue.png'); color: var(--awj-white); }
  .mx-card--black  { background-color: var(--awj-black); background-image: url('/assets/textures/paper_black.png'); color: var(--awj-white); }
  .mx-card__num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }
  .mx-card__line {
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 0.95;
    margin: 0;
    flex: 1;
    overflow-wrap: anywhere;
  }
</style>
