---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Andy Whyte Journal — applied thinking from an enterprise SaaS operator',
  description = 'Maxims, essays, and frameworks from Andy Whyte across sales, founding, and being human. One entry every Friday. No noise.',
  ogImage = '/assets/logos/awj_main_logo_yellow.png',
  noIndex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.andywhyte.com';
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
---
<!doctype html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="AWJ — Andy Whyte Journal" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicons -->
  <link rel="icon" type="image/png" href="/assets/logos/awj_submark_yellow.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Caveat:wght@400;700&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="AWJ Journal" href="/journal/rss.xml" />

  <slot name="head" />
</head>
<body>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
  /* Hide scrollbar styling that fights paper aesthetic */
  ::selection { background: var(--awj-yellow); color: var(--awj-black); }
</style>
