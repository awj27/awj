---
import { PILLAR_META, type Pillar } from '../lib/utils';
interface Props { pillar: Pillar; }
const { pillar } = Astro.props;
const meta = PILLAR_META[pillar];
---
<a href={`/pillars/${pillar}/`} class={`awj-pillar awj-pillar--${pillar}`}>
  <span class="awj-pillar__dot" aria-hidden="true"></span>
  <span>{meta.label}</span>
</a>

<style>
  .awj-pillar {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 3px;
    border: var(--border-hard);
    background: var(--awj-white);
    color: var(--awj-black);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--radius-pill);
    transition: background var(--t-fast), color var(--t-fast);
  }
  .awj-pillar:hover { background: var(--awj-black); color: var(--awj-white); }
  .awj-pillar:hover .awj-pillar__dot { background: var(--awj-yellow); }
  .awj-pillar__dot {
    width: 8px; height: 8px; border-radius: 50%;
  }
  .awj-pillar--sales .awj-pillar__dot   { background: var(--awj-yellow); }
  .awj-pillar--founder .awj-pillar__dot { background: var(--awj-blue); }
  .awj-pillar--human .awj-pillar__dot   { background: var(--awj-black); }
</style>
