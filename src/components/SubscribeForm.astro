---
// Beehiiv subscribe — proper inline AWJ-styled form that POSTs through
// our /api/subscribe Cloudflare Function (uses Beehiiv API server-side).
// User never leaves andywhyte.com.

interface Props { tone?: 'light' | 'dark' | 'yellow'; compact?: boolean; }
const { tone = 'light', compact = false } = Astro.props;
const formId = `awj-subscribe-${Math.random().toString(36).slice(2, 9)}`;
---
<form class={`awj-subscribe awj-subscribe--${tone}`} id={formId} novalidate>
  {!compact && (
    <label class="awj-subscribe__label" for={`${formId}-email`}>
      Get one entry every Friday
    </label>
  )}
  <div class="awj-subscribe__row">
    <input
      type="email"
      id={`${formId}-email`}
      name="email"
      required
      autocomplete="email"
      placeholder="you@work.com"
      class="awj-subscribe__input"
      aria-describedby={`${formId}-msg`}
    />
    <button type="submit" class="awj-subscribe__btn">Subscribe →</button>
  </div>
  <p class="awj-subscribe__fineprint" id={`${formId}-msg`} aria-live="polite">No spam. One email a week. Unsubscribe whenever.</p>
</form>

<style>
  .awj-subscribe { display: block; max-width: 540px; }
  .awj-subscribe__label {
    display: block;
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: var(--sp-3);
  }
  .awj-subscribe__row { display: flex; flex-direction: column; gap: var(--sp-2); }
  @media (min-width: 520px) { .awj-subscribe__row { flex-direction: row; } }
  .awj-subscribe__input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 16px;
    padding: 14px 16px;
    background: var(--awj-white);
    color: var(--awj-black);
    border: var(--border-hard);
    border-radius: 0;
    min-width: 0;
  }
  .awj-subscribe__input:focus { outline: 2px solid var(--awj-yellow); outline-offset: -4px; }
  .awj-subscribe__btn {
    font-family: var(--font-body);
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 14px 22px;
    background: var(--awj-black);
    color: var(--awj-white);
    border: var(--border-hard);
    border-radius: 0;
    cursor: pointer;
    transition: background var(--t-fast), color var(--t-fast);
    flex-shrink: 0;
  }
  .awj-subscribe__btn:hover { background: var(--awj-yellow); color: var(--awj-black); }
  .awj-subscribe__btn:disabled { opacity: 0.7; cursor: wait; }
  .awj-subscribe__fineprint {
    margin: var(--sp-3) 0 0;
    font-size: 12px;
    color: var(--fg-3);
  }
  .awj-subscribe[data-state='success'] .awj-subscribe__fineprint { color: var(--awj-blue); font-weight: 700; }
  .awj-subscribe[data-state='error']   .awj-subscribe__fineprint { color: var(--awj-red);  font-weight: 700; }

  /* Dark surface variant (e.g. inside the blue paper CTA section on /home) */
  .awj-subscribe--dark .awj-subscribe__label { color: var(--awj-yellow); }
  .awj-subscribe--dark .awj-subscribe__input { background: var(--awj-white); color: var(--awj-black); border-color: var(--awj-white); }
  .awj-subscribe--dark .awj-subscribe__btn   { background: var(--awj-yellow); color: var(--awj-black); border-color: var(--awj-yellow); }
  .awj-subscribe--dark .awj-subscribe__btn:hover { background: var(--awj-white); color: var(--awj-black); }
  .awj-subscribe--dark .awj-subscribe__fineprint { color: rgba(255,255,255,0.7); }

  /* Yellow surface variant (e.g. /subscribe hero) */
  .awj-subscribe--yellow .awj-subscribe__input { background: var(--awj-white); color: var(--awj-black); border-color: var(--awj-black); }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('form.awj-subscribe').forEach(form => {
    form.addEventListener('submit', async e => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]')!;
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
      const msg = form.querySelector<HTMLElement>('.awj-subscribe__fineprint')!;
      const email = input.value.trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        form.dataset.state = 'error';
        msg.textContent = 'Please enter a valid email address.';
        input.focus();
        return;
      }
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = 'Subscribing…';
      msg.textContent = '';
      form.dataset.state = '';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = (await res.json()) as { ok: boolean; message?: string; error?: string };
        if (data.ok) {
          form.dataset.state = 'success';
          msg.textContent = data.message ?? "You're in. Check your inbox to confirm.";
          input.value = '';
          btn.textContent = 'Subscribed ✓';
        } else {
          form.dataset.state = 'error';
          msg.textContent = data.error ?? 'Subscription failed. Please try again.';
          btn.disabled = false;
          btn.textContent = original ?? 'Subscribe →';
        }
      } catch {
        form.dataset.state = 'error';
        msg.textContent = 'Network error. Please try again.';
        btn.disabled = false;
        btn.textContent = original ?? 'Subscribe →';
      }
    });
  });
</script>
