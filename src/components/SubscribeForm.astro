---
// Beehiiv subscribe — iframe of the publication URL.
//
// Why iframe and not a native form: Beehiiv (like Substack) blocks
// cross-origin POSTs to their /create endpoint with bot management.
// BUT unlike Substack, Beehiiv allows iframe embedding, so we frame
// awj.beehiiv.com and the form inside it submits as same-origin.
//
// When Andy creates a custom inline embed in Beehiiv's "Subscribe Forms"
// UI, we swap this iframe URL for the embed-id URL. The wrapper styling
// stays the same.

interface Props { tone?: 'light' | 'dark' | 'yellow'; compact?: boolean; }
const { tone = 'light', compact = false } = Astro.props;
const PUBLICATION = 'https://awj.beehiiv.com/';
---
<div class={`awj-subscribe awj-subscribe--${tone}`}>
  {!compact && (
    <p class="awj-subscribe__pitch">
      <strong>One entry. Every Friday. No noise.</strong>
      <span> Join the journal. Hosted on Beehiiv — your email goes straight to the list.</span>
    </p>
  )}
  <div class="awj-subscribe__frame">
    <iframe
      src={PUBLICATION}
      title="Subscribe to Andy Whyte Journal"
      loading="lazy"
      frameborder="0"
      scrolling="no"
      width="100%"
      height="540"
      style="background: white;"
    ></iframe>
  </div>
  <p class="awj-subscribe__fineprint">No spam. One email a week. Unsubscribe whenever.</p>
</div>

<style>
  .awj-subscribe { display: block; max-width: 640px; }
  .awj-subscribe__pitch {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.5;
    margin: 0 0 var(--sp-3);
    color: inherit;
  }
  .awj-subscribe__pitch strong {
    font-weight: 800;
    font-size: 13px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 4px;
  }
  .awj-subscribe__frame {
    border: var(--border-hard);
    background: var(--awj-white);
    overflow: hidden;
  }
  .awj-subscribe__frame iframe {
    display: block;
    width: 100%;
    border: 0;
  }
  .awj-subscribe__fineprint { margin: var(--sp-3) 0 0; font-size: 12px; color: var(--fg-3); opacity: 0.85; }

  .awj-subscribe--dark .awj-subscribe__pitch { color: var(--awj-white); }
  .awj-subscribe--dark .awj-subscribe__pitch strong { color: var(--awj-yellow); }
  .awj-subscribe--dark .awj-subscribe__fineprint { color: rgba(255,255,255,0.7); }
  .awj-subscribe--dark .awj-subscribe__frame { border-color: var(--awj-yellow); }

  .awj-subscribe--yellow .awj-subscribe__frame { border-color: var(--awj-black); }
</style>
