---
// Masonry gallery via CSS multi-column. Each image keeps its natural
// aspect ratio — no forced cropping that lops heads off.

interface Props { images: { src: string; alt: string }[]; }
const { images } = Astro.props;
---
<div class="awj-gallery">
  {images.map(img => (
    <figure class="awj-gallery__tile">
      <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
    </figure>
  ))}
</div>

<style>
  .awj-gallery {
    column-count: 1;
    column-gap: var(--sp-4);
  }
  @media (min-width: 600px)  { .awj-gallery { column-count: 2; } }
  @media (min-width: 1100px) { .awj-gallery { column-count: 3; } }

  .awj-gallery__tile {
    margin: 0 0 var(--sp-4);
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
    overflow: hidden;
    border: var(--border-hard);
    background: var(--awj-paper);
    transition: transform var(--t-base) var(--ease-out), box-shadow var(--t-base) var(--ease-out);
  }
  .awj-gallery__tile:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--awj-black);
  }
  .awj-gallery__tile img {
    width: 100%;
    height: auto;          /* natural aspect ratio — no cropping */
    display: block;
  }
</style>
