# AWJ — environment variables
# Copy to `.env` for local dev; production values live in Cloudflare Pages
# (Workers & Pages → AWJ → Settings → Environment variables).

# ─── Beehiiv (subscribe form) ───────────────────────────────────────────
# Bearer token from Beehiiv → Settings → API
BEEHIIV_API_KEY=
# Publication ID, format pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BEEHIIV_PUBLICATION_ID=

# ─── Resend (contact form) ──────────────────────────────────────────────
RESEND_API_KEY=
CONTACT_NOTIFY_EMAIL=hello@andywhyte.com
# Until andywhyte.com is verified in Resend, use the sandbox sender:
#   AWJ Contact <onboarding@resend.dev>
CONTACT_FROM_ADDRESS=AWJ Contact <contact@andywhyte.com>

# ─── Analytics ──────────────────────────────────────────────────────────
# Google Analytics 4 — measurement ID (G-XXXXXXXXXX). PUBLIC_ prefix means
# this value ships to the client (it's safe; GA's client-side ID is meant
# to be public). Leave blank to disable GA entirely.
PUBLIC_GA_MEASUREMENT_ID=

# Measurement Protocol API secret — server-side only, never PUBLIC_.
# Used by /api/subscribe to fire `subscribe_success` from the server.
# Created in GA → Admin → Data Streams → [stream] → Measurement Protocol
# API secrets → Create. Encrypt this in Cloudflare Pages.
GA_API_SECRET=

# Cloudflare Web Analytics — beacon site token. Adds Core Web Vitals and
# per-path engagement on top of the auto-attached Pages analytics.
# Cloudflare → Web Analytics → [site] → JS snippet token.
PUBLIC_CF_ANALYTICS_TOKEN=
